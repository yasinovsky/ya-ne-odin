{% extends "/layouts/default.twig" %}



{% block content %}

    <div class="py-5 text-center">
        <img class="d-block mx-auto mb-4" src="/resources/logo.svg" width="100" alt="Я не один!">
        <h1 class="h2">Ошибка {{ code }}</h1>
        <div class="row">
            <div class="col-2"></div>
            <div class="col-8"><p class="lead">{{ message }}</p></div>
            <div class="col-2"></div>
        </div>
        <div class="mt-5">
            <a class="btn btn-primary" href="/" role="button">Вернуться на главную</a>
        </div>
    </div>

{% endblock %}
